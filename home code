<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lets Learn</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: url('your-image.png') no-repeat center/cover;
    height: 100vh;
}

/* NAVBAR */
.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 20px;
    background: rgba(0,0,0,0.6);
    color: white;
}

.nav-links {
    display: flex;
    gap: 10px;
}

.nav-links a {
    text-decoration: none;
    color: white;
    font-size: 14px;
}

/* TITLE */
.title {
    text-align: center;
    margin-top: 15vh;
    font-size: 70px;
    font-weight: bold;
    background: linear-gradient(90deg, red, orange, yellow, green, blue, violet);
    background-size: 300%;
    -webkit-background-clip: text;
    color: transparent;
    animation: rainbowText 5s infinite linear;
}

@keyframes rainbowText {
    0% { background-position: 0%; }
    100% { background-position: 300%; }
}

/* BUTTONS */
.buttons {
    text-align: center;
    margin-top: 30px;
}

.btn {
    padding: 15px 25px;
    margin: 10px;
    border-radius: 25px;
    border: none;
    font-size: 16px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: 0.3s;
}

/* COLORS */
.read { background: #6BCB77; }
.play { background: white; }
.quiz { background: #4D96FF; color: white; }

/* 🌈 RAINBOW GLOW */
.btn:hover {
    box-shadow: 0 0 10px red,
                0 0 20px orange,
                0 0 30px yellow,
                0 0 40px green,
                0 0 50px blue,
                0 0 60px violet;
    transform: scale(1.08);
}

/* 💥 BURST EFFECT */
.btn span {
    position: absolute;
    border-radius: 50%;
    transform: scale(0);
    background: radial-gradient(circle, white, transparent);
    animation: burst 0.5s ease-out;
    pointer-events: none;
}

@keyframes burst {
    to {
        transform: scale(8);
        opacity: 0;
    }
}

/* SUBTEXT */
.sub {
    text-align: center;
    color: white;
    margin-top: 10px;
}

/* 📱 MOBILE */
@media (max-width: 600px) {
    .title {
        font-size: 40px;
    }

    .btn {
        display: block;
        width: 80%;
        margin: 10px auto;
    }

    .navbar {
        flex-direction: column;
        gap: 10px;
    }
}
</style>
</head>

<body>

<!-- SOUND -->
<audio id="clickSound" src="https://www.soundjay.com/buttons/sounds/button-16.mp3"></audio>

<div class="navbar">
    <div>LOGO</div>
    <div class="nav-links">
        <a href="#">HOME</a>
        <a href="#">SERVICES</a>
        <a href="#">ABOUT</a>
        <a href="#">CONTACT</a>
    </div>
    <div>
        <button>Sign In</button>
        <button>Log In</button>
    </div>
</div>

<h1 class="title">LET'S LEARN!</h1>

<div class="buttons">
    <button class="btn read" onclick="goPage('read.html')">LETS READ</button>
    <button class="btn play" onclick="goPage('play.html')">LETS PLAY</button>
    <button class="btn quiz" onclick="goPage('quiz.html')">LETS QUIZ</button>
</div>

<p class="sub">Play, explore, and learn with us!</p>

<script>
const sound = document.getElementById("clickSound");

// SOUND + BURST EFFECT
document.querySelectorAll('.btn').forEach(button => {
    button.addEventListener('click', function(e) {
        
        // 🔊 play sound
        sound.currentTime = 0;
        sound.play();

        // 💥 burst
        const circle = document.createElement("span");
        const size = 10;

        circle.style.width = size + "px";
        circle.style.height = size + "px";
        circle.style.left = e.offsetX + "px";
        circle.style.top = e.offsetY + "px";

        this.appendChild(circle);

        setTimeout(() => {
            circle.remove();
        }, 500);
    });
});

// 🧠 NAVIGATION
function goPage(page) {
    setTimeout(() => {
        window.location.href = page;
    }, 200);
}
</script>

</body>
</html>
